{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://whatever-to-eat.local/schemas/UserInput.json",
    "title": "UserInput",
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "description": "可选：一次请求的追踪 id" },
  
      "mode": {
        "type": "string",
        "enum": ["delivery", "dine_in", "cook"],
        "description": "delivery=外卖, dine_in=堂食, cook=自己做饭"
      },
  
      "people_count": {
        "type": "integer",
        "minimum": 1,
        "description": "可选：用餐人数（用于份量/人均预算口径）"
      },
  
      "time": {
        "type": "string",
        "enum": ["noon", "evening", "midnight"],
        "description": "可选：用餐时间段（noon=午餐, evening=晚餐, midnight=宵夜）"
      },
  
      "budget": {
        "description": "可选：预算。建议用数字（实现决定单位：总价或人均）。如需区间，用对象 min/max。",
        "type": "number",
        "minimum": 0,
        "maximum": 1000
      },
  
      "location": {
        "type": "string",
        "minLength": 1,
        "description": "可选：地标/区域/经纬度描述；当 mode=delivery 或 dine_in 时建议必填"
      },
  
      "constraints": {
        "description": "可选：额外限制，如不吃辣/少油/清淡/不吃蒜等",
        "type": "string",
        "minLength": 1
      },
  
      "liked_flavors": {
        "description": "可选：喜欢口味（甜/咸/酸/辣/麻/清淡/重口等）",
        "oneOf": [
          { "type": "string" },
          {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        ]
      },
  
      "disliked_flavors": {
        "description": "可选：不喜欢口味",
        "oneOf": [
          { "type": "string" },
          {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        ]
      },
  
      "diet_restrictions": {
        "description": "可选：忌口/过敏（硬性约束）",
        "oneOf": [
          { "type": "string" },
          {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        ]
      },
  
      "cooking_skill": {
        "type": "integer",
        "minimum": 0,
        "maximum": 3,
        "description": "可选：做饭难度/能力（0-3 档，建议你后续约定含义）"
      },
  
      "rating_last": {
        "description": "可选：对上一顿的反馈",
        "type": "string",
        "enum": ["like", "neutral", "dislike"]
      },
  
      "history_window": {
        "description": "可选：近期窗口定义（用于不重复策略），例如：recent_5_days / recent_10_meals",
        "type": "string"
      },
  
      "history_entries": {
        "description": "可选：历史记录（用于 prompt 注入/不重复约束）。后续：HistoryEntry schema。",
        "type": "array",
        "items": { "type": "object" }
      },
  
      "candidate_pool_json": {
        "description": "可选：外部候选池（如果你选择让 LLM 在候选中选，而不是自己凭空生成）。后续：Candidate schema。",
        "type": "array",
        "items": { "type": "object" }
      }
    },
    "required": ["mode"],
    "allOf": [
      {
        "if": {
          "properties": { "mode": { "enum": ["delivery", "dine_in"] } },
          "required": ["mode"]
        },
        "then": {
          "required": ["location"]
        }
      }
    ]
  }