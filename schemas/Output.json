{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whatever-to-eat.local/schemas/Output.json",
  "title": "Output",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "可选：一次请求的追踪 id（通常与 UserInput.id 对齐）"
    },
    "mode": {
      "type": "string",
      "enum": ["delivery", "dine_in", "cook"],
      "description": "输出所对应的就餐方式"
    },
    "main_recommendation": {
      "oneOf": [
        { "$ref": "#/$defs/MainRecommendationDelivery" },
        { "$ref": "#/$defs/MainRecommendationDineIn" },
        { "$ref": "#/$defs/MainRecommendationCook" }
      ]
    },
    "alternatives": {
      "type": "array",
      "description": "2-3 个备选（同样给出简要理由）",
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/AlternativeDeliveryItem" },
          { "$ref": "#/$defs/AlternativeDineInItem" },
          { "$ref": "#/$defs/AlternativeCookItem" }
        ]
      }
    },
    "response": {
      "type": "string",
      "description": "对用户的自然回复和解释推荐原因",
      "minLength": 1
    }
  },
  "required": ["mode", "main_recommendation", "alternatives", "response"],
  "allOf": [
    {
      "if": {
        "properties": { "mode": { "const": "delivery" } },
        "required": ["mode"]
      },
      "then": {
        "properties": {
          "main_recommendation": { "$ref": "#/$defs/MainRecommendationDelivery" },
          "alternatives": { "items": { "$ref": "#/$defs/AlternativeDeliveryItem" } }
        }
      }
    },
    {
      "if": {
        "properties": { "mode": { "const": "dine_in" } },
        "required": ["mode"]
      },
      "then": {
        "properties": {
          "main_recommendation": { "$ref": "#/$defs/MainRecommendationDineIn" },
          "alternatives": { "items": { "$ref": "#/$defs/AlternativeDineInItem" } }
        }
      }
    },
    {
      "if": {
        "properties": { "mode": { "const": "cook" } },
        "required": ["mode"]
      },
      "then": {
        "properties": {
          "main_recommendation": { "$ref": "#/$defs/MainRecommendationCook" },
          "alternatives": { "items": { "$ref": "#/$defs/AlternativeCookItem" } }
        }
      }
    }
  ],
  "$defs": {
    "NutritionTags": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "protein": {
          "description": "蛋白质要素（肉/鱼/蛋/豆制品等），可为字符串或字符串数组",
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" }, "minItems": 1 }
          ]
        },
        "veg": {
          "description": "蔬菜/水果要素，可为字符串或字符串数组",
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" }, "minItems": 1 }
          ]
        },
        "carbs": {
          "description": "主食/碳水要素，可为字符串或字符串数组",
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" }, "minItems": 1 }
          ]
        },
        "fat": {
          "description": "脂肪要素/来源，可为字符串或字符串数组",
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" }, "minItems": 1 }
          ]
        }
      },
      "required": ["protein", "veg", "carbs", "fat"]
    },

    "MainRecommendationDelivery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider_name": { "type": "string", "minLength": 1, "description": "店铺/餐厅名称" },
        "dish_name_or_category": { "type": "string", "minLength": 1, "description": "菜品名或菜品类型" },
        "description": { "type": "string", "description": "简要描述（卖点/口味/适配点）" },
        "reason": { "type": "string", "description": "为何推荐（与偏好、忌口、近期不重复相关）" },
        "estimated_cost": { "type": "number", "minimum": 0, "description": "预计成本（实现阶段可定义单位）" },
        "estimated_duration_minutes": { "type": "integer", "minimum": 1, "description": "预计耗时（外卖时可理解为送达/准备时长）" },
        "nutrition_tags": { "$ref": "#/$defs/NutritionTags", "description": "营养标签（外卖仅用于展示与解释）" }
      },
      "required": [
        "provider_name",
        "dish_name_or_category",
        "description",
        "reason",
        "nutrition_tags"
      ]
    },

    "MainRecommendationDineIn": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider_name": { "type": "string", "minLength": 1, "description": "餐馆名称" },
        "dish_name_or_category": {"description": "菜品名或菜品类型", 
                                "type": "oneOf",
                                "items": {
                                    "oneOf": [
                                        { "type": "string" },
                                        { "type": "array", "items": { "type": "string" }, "minItems": 1 }
                                    ]
                                }
        },
        "description": { "type": "string", "description": "简要描述（卖点/口味/适配点）" },
        "reason": { "type": "string", "description": "为何推荐（与偏好、忌口、近期不重复相关）" },
        "estimated_arrival_minutes": { "type": "integer", "minimum": 1, "description": "预计到达时长（实现阶段口径）" },
        "estimated_dine_duration_minutes": { "type": "integer", "minimum": 1, "description": "预计就餐时长（实现阶段口径）" },
        "estimated_cost": { "type": "number", "minimum": 0, "description": "预计成本（实现阶段可定义单位）" },
        "nutrition_tags": { "$ref": "#/$defs/NutritionTags", "description": "营养标签（堂食仅用于展示与解释）" }
      },
      "required": [
        "provider_name",
        "dish_name_or_category",
        "description",
        "reason",
        "nutrition_tags"
      ]
    },

    "Ingredient": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1, "description": "食材名" },
        "amount": { "type": "number", "minimum": 0, "description": "预计用量（粗粒度，可选）" },
        "unit": { "type": "string", "description": "用量单位（可选）" },
        "notes": { "type": "string", "description": "额外说明（可选）" }
      },
      "required": ["name"]
    },

    "ReplacementSuggestion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "missing_item": { "type": "string", "minLength": 1, "description": "缺失的食材/品类（或假设缺失项）" },
        "replacement_name": { "type": "string", "minLength": 1, "description": "替代品名称" },
        "rationale": { "type": "string", "description": "替换理由（口味/结构/营养要素匹配等）" }
      },
      "required": ["missing_item", "replacement_name", "rationale"]
    },

    "MainRecommendationCook": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recipe_name": { "type": "string", "minLength": 1, "description": "菜谱/做法名称" },
        "key_cooking_steps": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "关键做法步骤（简述）"
        },
        "ingredients": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Ingredient" },
          "description": "食材清单（用于购物/准备）"
        },
        "estimated_time_minutes": { "type": "integer", "minimum": 1, "description": "预计用时（实现阶段口径）" },
        "servings_notes": { "type": "string", "description": "与人数相关的份量说明（可选）" },
        "replacement_suggestions": {
          "type": "array",
          "description": "2 个替换建议（缺食材时怎么替换）",
          "minItems": 2,
          "maxItems": 2,
          "items": { "$ref": "#/$defs/ReplacementSuggestion" }
        },
        "reason": { "type": "string", "description": "为何推荐（与口味/忌口/近期不重复/营养覆盖等相关）" },
        "nutrition_tags": { "$ref": "#/$defs/NutritionTags", "description": "营养标签（cook 模式用于营养均衡目标）" }
      },
      "required": [
        "recipe_name",
        "key_cooking_steps",
        "ingredients",
        "estimated_time_minutes",
        "replacement_suggestions",
        "reason",
        "nutrition_tags"
      ]
    },

    "AlternativeDeliveryItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider_name": { "type": "string", "minLength": 1 },
        "dish_name_or_category": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "description": "简要理由" },
        "estimated_cost": { "type": "number", "minimum": 0 },
        "estimated_duration_minutes": { "type": "integer", "minimum": 1 },
        "nutrition_tags": { "$ref": "#/$defs/NutritionTags" }
      },
      "required": ["provider_name", "dish_name_or_category", "reason", "nutrition_tags"]
    },

    "AlternativeDineInItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider_name": { "type": "string", "minLength": 1 },
        "dish_name_or_category": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "description": "简要理由" },
        "estimated_cost": { "type": "number", "minimum": 0 },
        "estimated_arrival_minutes": { "type": "integer", "minimum": 1 },
        "estimated_dine_duration_minutes": { "type": "integer", "minimum": 1 },
        "nutrition_tags": { "$ref": "#/$defs/NutritionTags" }
      },
      "required": ["provider_name", "dish_name_or_category", "reason", "nutrition_tags"]
    },

    "AlternativeCookItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recipe_name": { "type": "string", "minLength": 1 },
        "brief_description": { "type": "string", "description": "简要描述（做法/适配点）" },
        "reason": { "type": "string", "description": "简要理由" },
        "estimated_time_minutes": { "type": "integer", "minimum": 1 },
        "nutrition_tags": { "$ref": "#/$defs/NutritionTags" }
      },
      "required": ["recipe_name", "brief_description", "reason", "estimated_time_minutes", "nutrition_tags"]
    }
    
  }
}